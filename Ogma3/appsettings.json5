{
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft": "Warning",
			"Microsoft.Hosting.Lifetime": "Information",
		},
	},
	"AllowedHosts": "*",
	"Domain": "beta.genfic.net",
	"AdditionalHeaders": {
		"Headers": {
			"X-Robots-Tag": "noai, noimageai",
			"TDM-Reservation": "1",
		},
	},
	"Time": {
		"UseBuiltInTimezoneStyle": true,
	},
	"Infisical": {
		"Url": "https://eu.infisical.com",
	},
}
