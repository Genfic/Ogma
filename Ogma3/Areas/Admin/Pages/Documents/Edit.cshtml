@page "{slug}"
@using Ogma3.Infrastructure.Constants
@model Ogma3.Areas.Admin.Pages.Documents.EditModel

@{
	ViewData["Title"] = "Edit Document";
	ViewData["ActivePage"] = NavPages.Documents;
}

<h1>@Model.Input.Title</h1>

<form method="post" id="editor" class="form">

	<div class="o-form-group">
		<label asp-for="@Model.Input.Body"></label>
		<textarea asp-for="@Model.Input.Body"
		          cols="30" rows="10"
		          class="o-form-control active-border">
        </textarea>
	</div>

	<details>
		<summary>Advanced</summary>

		<div class="o-form-group">
			<label asp-for="@Model.Input.CustomCss"></label>
			<textarea asp-for="@Model.Input.CustomCss"
			          cols="30" rows="10"
			          class="o-form-control active-border">
	        </textarea>
		</div>

		@if (User.IsInRole(RoleNames.Admin))
		{
			<div class="o-form-group">
				<label asp-for="@Model.Input.CustomJs"></label>
				<textarea asp-for="@Model.Input.CustomJs"
				          cols="30" rows="10"
				          class="o-form-control active-border">
				</textarea>
			</div>
		}
	</details>

	<input asp-for="@Model.Input.Slug" type="hidden">

	<div class="o-form-group">
		<button type="submit" class="btn btn-primary">Create version @(Model.Input.Version + 1)</button>
	</div>
</form>