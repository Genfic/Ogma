@page
@model Settings

@{
	ViewData["Title"] = "Settings";
	ViewData["ActivePage"] = NavPages.Settings;
}

<autoform
	for="@Model.Config"
	datalist-for-PrivacyPolicyDoc="@Model.DocNames"
	datalist-for-AboutDoc="@Model.DocNames"
	datalist-for-TosDoc="@Model.DocNames"
	datalist-for-SearchHelpDoc="@Model.DocNames"
></autoform>

@section Scripts
{
	<script type="module" src="~/js/admin/settings.js" asp-append-version="true"></script>
}