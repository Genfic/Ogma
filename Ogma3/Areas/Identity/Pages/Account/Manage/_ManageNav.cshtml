@using Ogma3.Data.Users
@inject SignInManager<OgmaUser> SignInManager
@{
	var hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
}
<ul class="nav nav-pills flex-column">
	<li class="nav-item @ManageNavPages.IndexNavClass(ViewContext)">
		<a class="nav-link" id="manage-profile" asp-page="./Index">Profile</a>
	</li>

	<li class="nav-item @ManageNavPages.SubscriptionNavClass(ViewContext)">
		<a class="nav-link" id="subscription" asp-page="./Subscription">Subscription</a>
	</li>

	<li class="nav-item @ManageNavPages.BlacklistsNavClass(ViewContext)">
		<a class="nav-link" id="blacklists" asp-page="./Blacklists">Blacklists</a>
	</li>

	<li class="nav-item @ManageNavPages.InviteCodesNavClass(ViewContext)">
		<a class="nav-link" id="invite-codes" asp-page="./InviteCodes">Invite codes</a>
	</li>

	<li class="nav-item @ManageNavPages.EmailNavClass(ViewContext)">
		<a class="nav-link" id="email" asp-page="./Email">Email</a>
	</li>

	<li class="nav-item @ManageNavPages.ChangePasswordNavClass(ViewContext)">
		<a class="nav-link" id="change-password" asp-page="./ChangePassword">Password</a>
	</li>

	@if (hasExternalLogins)
	{
		<li id="external-logins" class="nav-item @ManageNavPages.ExternalLoginsNavClass(ViewContext)">
			<a id="external-login" class="nav-link" asp-page="./ExternalLogins">External logins</a>
		</li>
	}

	<li class="nav-item @ManageNavPages.TwoFactorAuthenticationNavClass(ViewContext)">
		<a class="nav-link" id="two-factor" asp-page="./TwoFactorAuthentication">Two-factor authentication</a>
	</li>

	<li class="nav-item @ManageNavPages.PasskeysNavClass(ViewContext)">
		<a class="nav-link" id="passkeys" asp-page="./Passkeys">Passkeys</a>
	</li>

	<li class="nav-item @ManageNavPages.PersonalDataNavClass(ViewContext)">
		<a class="nav-link" id="personal-data" asp-page="./PersonalData">Personal data</a>
	</li>

	<li class="nav-item @ManageNavPages.InfractionsNavClass(ViewContext)">
		<a class="nav-link" id="infractions" asp-page="./Infractions">Infractions</a>
	</li>
</ul>