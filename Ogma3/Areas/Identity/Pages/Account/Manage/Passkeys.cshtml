@page
@using Microsoft.AspNetCore.Antiforgery
@model Passkeys
@inject IAntiforgery Csrf
@{
	ViewData["Title"] = "Passkeys";
	ViewData["ActivePage"] = ManageNavPages.Passkeys;
}

<setup-passkey csrf="@Csrf.GetAndStoreTokens(HttpContext).RequestToken"></setup-passkey>

<script type="module" src="~/js/account/setup-passkey.js" asp-append-version="true" asp-add-nonce="true"></script>