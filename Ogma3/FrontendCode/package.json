{
	"name": "ogma-3",
	"version": "beta",
	"sideEffects": false,
	"type": "module",
	"scripts": {
		"webtypes": "bun ./scripts/webtypes.ts",
		"biome": "bunx biome check --write",
		"biome:report": "bun ./scripts/biome-check.tsx",
		"css": "bun ./scripts/build-sass.ts",
		"css:lint": "bunx stylelint '**/*.scss'",
		"css:watch": "bun ./scripts/build-sass.ts -- --watch",
		"js": "bun ./scripts/build-js.ts",
		"js:watch": "bun ./scripts/build-js.ts -- --watch",
		"js:typecheck": "tsc --project ./typescript --noEmit",
		"fonts": "bun ./scripts/build-fonts.ts",
		"lh": "bunx unlighthouse",
		"build": "bun run css -- -c && bun run js -- -c && bun run fonts"
	},
	"devDependencies": {
		"@angius/bun-plugin-solid": "^1.4.2",
		"@biomejs/biome": "^2.4.15",
		"@commander-js/extra-typings": "^14.0.0",
		"@happy-dom/global-registrator": "^20.9.0",
		"@parcel/watcher": "^2.5.6",
		"@socketsecurity/bun-security-scanner": "^1.1.2",
		"@stylelint-types/stylelint-scss": "^7.0.1",
		"@types/ansi-colors": "^3.2.6",
		"@types/bun": "^1.3.14",
		"@types/ejs": "^3.1.5",
		"@types/json5": "^2.2.0",
		"@types/node": "^25.8.0",
		"@typescript/native-preview": "^7.0.0-dev.20260516.1",
		"chalk": "^5.6.2",
		"chalk-template": "^1.1.2",
		"cheerio": "^1.2.0",
		"commander": "^14.0.3",
		"convert": "^7.0.0",
		"ejs": "^5.0.2",
		"esbuild": "^0.28.0",
		"fonteditor-core": "^2.6.3",
		"lighthouse": "^13.3.0",
		"lightningcss": "^1.32.0",
		"sass-embedded": "^1.99.0",
		"solid-labels": "^0.17.0",
		"stylelint": "^17.11.1",
		"stylelint-config-standard-scss": "^17.0.0",
		"stylelint-define-config": "^17.11.0",
		"utility-types": "^3.11.0"
	},
	"dependencies": {
		"@angius/tinytime": "^1.2.0",
		"@atulin/html-sanitizer": "npm:@jsr/atulin__html-sanitizer@3.0.0",
		"@solid-primitives/destructure": "^0.2.3",
		"@solid-primitives/event-dispatcher": "^0.1.1",
		"@solid-primitives/intersection-observer": "^2.2.4",
		"@solid-primitives/scheduled": "^1.5.3",
		"@solid-primitives/storage": "^4.3.4",
		"clsx": "^2.1.1",
		"comlink": "^4.4.2",
		"es-toolkit": "^1.46.1",
		"hash-wasm": "^4.12.0",
		"marked": "^18.0.3",
		"sa11y": "^5.0.3",
		"solid-element": "^1.9.1",
		"solid-js": "^1.9.13",
		"solid-signals": "^1.9.1",
		"uqr": "^0.1.3",
		"valibot": "^1.4.0"
	},
	"web-types": [
		"./web-types.json"
	],
	"webtypesConfig": {
		"name": "Ogma Components",
		"version": "1.0.0",
		"framework": "solid",
		"description-markup": "markdown"
	}
}
