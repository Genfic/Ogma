{
	"name": "ogma-3",
	"version": "beta",
	"sideEffects": false,
	"type": "module",
	"scripts": {
		"webtypes": "bun ./scripts/webtypes.ts",
		"ctconfig": "bun ./scripts/generate-ctconfig.ts",
		"biome": "bunx biome check --write",
		"biome:report": "bun ./scripts/biome-check.ts",
		"css": "bun ./scripts/build-sass.ts",
		"css:lint": "bunx stylelint '**/*.scss'",
		"css:watch": "bun ./scripts/build-sass.ts -- --watch",
		"js": "bun ./scripts/build-js.ts",
		"js:watch": "bun ./scripts/build-js.ts -- --watch",
		"js:typecheck": "tsc --project ./typescript --noEmit",
		"icons": "bun ./scripts/build-icons.ts",
		"lh": "bunx unlighthouse",
		"build": "bun run css && bun run js && bun run webtypes && bun run icons"
	},
	"devDependencies": {
		"@angius/bun-plugin-solid": "^1.4.2",
		"@biomejs/biome": "^2.4.8",
		"@commander-js/extra-typings": "^14.0.0",
		"@happy-dom/global-registrator": "^20.8.4",
		"@parcel/watcher": "^2.5.6",
		"@socketsecurity/bun-security-scanner": "^1.1.2",
		"@stylelint-types/stylelint-scss": "^7.0.0",
		"@types/ansi-colors": "^3.2.6",
		"@types/bun": "^1.3.11",
		"@types/json5": "^2.2.0",
		"@types/node": "^25.5.0",
		"@typescript/native-preview": "^7.0.0-dev.20260319.1",
		"chalk": "^5.6.2",
		"chalk-template": "^1.1.2",
		"cheerio": "^1.2.0",
		"commander": "^14.0.3",
		"convert": "^7.0.0",
		"dedent": "^1.7.2",
		"ejs": "^5.0.1",
		"esbuild": "^0.27.4",
		"gradient-string": "^3.0.0",
		"json5": "^2.2.3",
		"lighthouse": "^13.0.3",
		"lightningcss": "^1.32.0",
		"sass-embedded": "^1.98.0",
		"sharp": "^0.34.5",
		"solid-labels": "^0.17.0",
		"stylelint": "^17.5.0",
		"stylelint-config-standard-scss": "^17.0.0",
		"stylelint-define-config": "^17.2.0",
		"utility-types": "^3.11.0",
		"zod": "^4.3.6"
	},
	"dependencies": {
		"@angius/tinytime": "^1.2.0",
		"@atulin/html-sanitizer": "npm:@jsr/atulin__html-sanitizer@3.0.0",
		"@solid-primitives/destructure": "^0.2.3",
		"@solid-primitives/event-dispatcher": "^0.1.1",
		"@solid-primitives/intersection-observer": "^2.2.4",
		"@solid-primitives/storage": "^4.3.4",
		"@types/ejs": "^3.1.5",
		"clsx": "^2.1.1",
		"comlink": "^4.4.2",
		"date-fns": "^4.1.0",
		"date-fns-tz": "^3.2.0",
		"es-toolkit": "^1.45.1",
		"hash-wasm": "^4.12.0",
		"marked": "^17.0.4",
		"sa11y": "^4.4.1",
		"solid-element": "^1.9.1",
		"solid-js": "^1.9.11",
		"solid-signals": "^1.9.1",
		"uqr": "^0.1.2",
		"valibot": "^1.3.1"
	},
	"web-types": [
		"./web-types.json"
	],
	"webtypesConfig": {
		"name": "Ogma Components",
		"version": "1.0.0",
		"framework": "solid",
		"description-markup": "markdown"
	}
}
